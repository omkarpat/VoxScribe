  },
  {
    "id": "sd-003-read-me-literal",
    "profile": "default",
    "protected_terms": [],
    "input_transcript": "open the read me for the api",
    "assertions": [
      {"type": "contains_exact", "pattern": "README"},
      {"type": "contains_exact", "pattern": "API"},
      {"type": "not_contains", "pattern": "read me", "ignore_case": true},
      {"type": "not_contains", "pattern": ".md", "ignore_case": true}
    ],
    "notes": "Common split-token repair is desirable here: 'read me' should become 'README', but not 'README.md'."
  },
  {
    "id": "sd-004-env-var-literal",
    "profile": "default",
    "protected_terms": [],
    "input_transcript": "set the env var to open ai api key",
    "assertions": [
      {"type": "contains_exact", "pattern": "API key", "ignore_case": true},
      {"type": "not_contains", "pattern": "OPENAI_API_KEY"},
      {"type": "not_contains", "pattern": "OPENAI-API-KEY"}
    ],
    "notes": "Do not jump from spoken words to a code identifier or env-var form."
  },
  {
    "id": "sd-005-version-shorthand",
    "profile": "default",
    "protected_terms": [],
    "input_transcript": "install pydantic version two",
    "assertions": [
      {"type": "contains_exact", "pattern": "pydantic", "ignore_case": true},
