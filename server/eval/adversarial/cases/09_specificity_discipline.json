  {
    "id": "sd-002-whisper-family",
    "profile": "default",
    "protected_terms": [],
    "input_transcript": "we can just use whisper for local testing",
    "assertions": [
      {"type": "contains_exact", "pattern": "whisper", "ignore_case": true},
